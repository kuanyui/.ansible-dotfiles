## (Required) Project name.
PROJECT_NAME =

## (Required) Project folder path in host. This folder will be mounted into `/home/user/MAIN` in container.
PROJECT_PATH =

## (Optional) OCI runtime for `podman run` (e.g. `crun`, `krun`). Empty = let podman pick (typically `crun` on modern distros).
## When set, `CONTAINER_NAME` is suffixed with `_$(RUNTIME)` so multiple runtime variants can coexist for the same project.
RUNTIME ?=

_RUNTIME_OPT := $(if $(RUNTIME),--runtime $(RUNTIME),)
_RUNTIME_SUFFIX := $(if $(RUNTIME),_$(RUNTIME),)

## (Optional) This will becomes the name of the built Image. (default: `{{ cfg.naming_prefix }}_image__${PROJECT_NAME}`)
IMAGE_NAME = {{ cfg.naming_prefix }}_image__$(PROJECT_NAME)

## (Optional) This will becomes the name of the created Container. (default: `{{ cfg.naming_prefix }}_container__${PROJECT_NAME}${_RUNTIME_SUFFIX}`)
CONTAINER_NAME = {{ cfg.naming_prefix }}_container__$(PROJECT_NAME)$(_RUNTIME_SUFFIX)

## (Optional) Hide `.git/` directory inside container. (default: `true`)
HIDE_GIT_DIR ?= true
## (Optional) Hide `.vscode/` directory inside container, for security concerning. (default: `true`)
HIDE_VSCODE_DIR ?= true

_CONTAINER_RUN_HIDE_DIRS_ARGS :=
_FAKE_MASK_DIR := /tmp/podman-mask-dir/$(CONTAINER_NAME)
ifeq ($(HIDE_GIT_DIR),true)
    # _CONTAINER_RUN_HIDE_DIRS_ARGS += --mount type=tmpfs,destination=/home/user/MAIN/.git    # USELESS. Fuck.
    # _CONTAINER_RUN_HIDE_DIRS_ARGS += --volume /dev/null:/home/user/MAIN/.git                # USELESS. Fuck.
    # _CONTAINER_RUN_HIDE_DIRS_ARGS += --mount type=bind,source=/dev/null,target=/home/user/MAIN/.git  # USELESS. Fuck.
    # _CONTAINER_RUN_HIDE_DIRS_ARGS += --mount type=tmpfs,destination=/home/user/MAIN/.git,tmpfs-mode=000,ro    # Unable to stop `root` in container.
    $(shell mkdir -p $(_FAKE_MASK_DIR))
    _CONTAINER_RUN_HIDE_DIRS_ARGS += --volume $(_FAKE_MASK_DIR):/home/user/MAIN/.git:ro,Z
endif
ifeq ($(HIDE_VSCODE_DIR),true)
    # _CONTAINER_RUN_HIDE_DIRS_ARGS += --volume /dev/null:/home/user/MAIN/.vscode
    $(shell mkdir -p $(_FAKE_MASK_DIR))
    _CONTAINER_RUN_HIDE_DIRS_ARGS += --volume $(_FAKE_MASK_DIR):/home/user/MAIN/.vscode:ro,Z
endif

# NOTE: Fuck, rootless AppArmor cannot use `--security-opt apparmor`, don't use this. Use libkrun if requires a real security runtime.
# [AppArmor] The AppArmor profile name to apply on `podman run`
AA_PROFILE := local_attachmentless_podman_ai_agent
_AA_OPT := $(shell \
      aa-enabled --quiet 2>/dev/null && \
      [ -f /etc/apparmor.d/$(AA_PROFILE) ] && \
      echo '--security-opt apparmor=$(AA_PROFILE)')
_check-aa-profile:   # [AppArmor] Check if AppArmor is installed & running & profile is existed
	@if [ -z '$(_AA_OPT)' ]; then \
	    echo "WARNING: AppArmor profile '$(AA_PROFILE)' not loaded - running without MAC enforcement." >&2; \
	    printf 'Continue? [y/N] '; \
	    read _ans; \
	    case "$$_ans" in y|Y) ;; *) exit 1;; esac; \
	fi

