# {{ ansible_managed }}

{% if who == 'user' %}
# - This is the ~/.bashrc inside the container
# - bash is reserved for compatibility. Please use zsh instead.
# - Comments are mostly in ~/.zshrc.
{% else %}
# This is the ~/.bashrc inside the container
{% endif %}

{{ shared_bash_ps1_line }}

# Prevent Emacs TRAMP from failed to match the shell prompt.
if [ "$TERM" = "dumb" ]; then
    PS1='$ '
    unset PROMPT_COMMAND
    [ -n "$ZSH_VERSION" ] && unsetopt zle 2>/dev/null
fi

{% if who == 'user' %}

PATH={% if cfg.nodejs %}${HOME}/.local/npm_global/bin:{% endif %}${HOME}/.local/bin:${PATH}

{% endif %}
alias sz="source ~/.bashrc"
{{ shared_aliases_ls }}
alias sc="sudo systemctl"
alias jc="sudo journalctl"
alias jc-clear="sudo journalctl --vacuum-time=5d"   #  Delete journal logs which are older than 5 days

{% if who == 'user' %}
alias nvv='nvm ls'
alias nv='nvm version'

{% endif %}
{{ shared_aliases_cd_shortcuts }}

export HISTCONTROL=ignorespace
{% if who == 'user' %}

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion
{% endif %}
